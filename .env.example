# Copy this file to .env and fill the values. Do NOT commit real credentials.

# Database credentials
DB_NAME=bhatkar_db
DB_USER=bhatkar_user
DB_PASSWORD=super_secure_password_here
DB_ROOT_PASSWORD=use_a_strong_root_password

# Port to expose on host (development only)
DB_PORT=3306

# Service hostname (Docker Compose service name) — used by Express when connecting from backend container
DB_HOST=db

# Timezone (optional)
TZ=UTC

# Notes:
# - For production, do not store secrets in plain .env; use Docker secrets or a secret manager.
# - If your Node MySQL client doesn't support caching_sha2_password, set MySQL to use
#   mysql_native_password by adding `command: --default-authentication-plugin=mysql_native_password`
#   to the db service in docker-compose.yml (not recommended unless necessary).
